# Black Locust API (required for cart, login, reviews, search)
# Must match backend PORT (default in repo: 5002). No trailing slash.
# Code appends /api automatically unless you already end with /api.
REACT_APP_API_URL=http://localhost:5002

# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# For Production (when you deploy)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Database (for backend if needed)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

