# Development Environment Variables
REACT_APP_ENV=development
REACT_APP_API_URL=http://localhost:5002
REACT_APP_SITE_URL=http://localhost:3000

# EmailJS Configuration (Development)
REACT_APP_EMAILJS_PUBLIC_KEY=dev_public_key
REACT_APP_EMAILJS_SERVICE_ID=dev_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=dev_template_id

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_ERROR_REPORTING=false
REACT_APP_ENABLE_PERFORMANCE_MONITORING=false

# Cache and Performance
REACT_APP_CACHE_DURATION=3600000
REACT_APP_API_TIMEOUT=10000
